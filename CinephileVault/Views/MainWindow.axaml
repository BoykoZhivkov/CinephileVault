<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CinephileVault.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CinephileVault.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="CinephileVault">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="10">
        <TextBox x:Name="SearchInput"
                 Watermark="Type movie title or employee role..."/>
        <Button Content="Search Title"
                Click="OnSearchTitleClick"
                HorizontalAlignment="Stretch"/>
        <Button Content="Search Role"
                Click="OnSearchRoleClick"
                HorizontalAlignment="Stretch"/>
        <Separator Margin="0,10"/>
        <TextBlock Text="Results:"/>
        <ListBox x:Name="ResultsList" Height="300"/>
    </StackPanel>
</Window>
